{
  "name": "webmunicipal",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "npm --prefix frontend install && npm --prefix frontend run build && npm --prefix backend install",
    "start": "node backend/server.js",
    "setup-users": "node backend/scripts/setup-users.js",
    "install:all": "npm --prefix frontend install && npm --prefix backend install"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^14.2.0",
    "nodemailer": "^9.0.3"
  }
}
